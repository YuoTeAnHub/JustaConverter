local function copyToClipboard(text)
    if setclipboard then
        setclipboard(text)
        return true
    elseif toclipboard then
        toclipboard(text)
        return true
    end
    return false
end

getButton.MouseButton1Click:Connect(function()
    local link = "https://discord.gg/thZ87CtPee"
    
    if copyToClipboard(link) then
        getButton.Text = "Copied to clipboard!"
        wait(2)
        getButton.Text = "Get New Version"
    else
        getButton.Text = "Link copied!"
        wait(2)
        getButton.Text = "Get New Version"
    end
end)

